generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id               String                 @id @default(uuid()) @db.Uuid
  code             String                 @unique
  name             String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  phone            String?
  address          String?
  isActive         Boolean                @default(true)
  academicYears    AcademicYear[]
  auditLogs        AuditLog[]
  enrollments      ClassEnrollment[]
  guardianContacts GuardianContact[]
  issuedReports    IssuedReport[]
  imports          MarkImportBatch[]
  subscription     ReportLabSubscription?
  classes          SchoolClass[]
  streams          Stream[]
  students         Student[]
  subjects         Subject[]
  users            User[]
  smartPagePayments SmartPagePaymentRequest[]
  promotionBatches  PromotionBatch[]
  promotionActions  PromotionAction[]
  studentCredentials StudentCredential[]
  studentWallets      StudentWallet[]
  studentWalletTransactions StudentWalletTransaction[]
  studentAttendanceEvents StudentAttendanceEvent[]
  nfcGateScans        NfcGateScan[]
  nfcTags             NfcTag[]
  nfcTagBatches       NfcTagBatch[]
}

model AcademicYear {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  name        String
  startsOn    DateTime
  endsOn      DateTime
  isActive    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
  marks       SubjectMark[]
  terms       Term[]

  @@unique([schoolId, name])
  @@index([schoolId, isActive])
}

model Term {
  id             String            @id @default(uuid()) @db.Uuid
  academicYearId String            @db.Uuid
  name           String
  startsOn       DateTime
  endsOn         DateTime
  isActive       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  enrollments    ClassEnrollment[]
  marks          SubjectMark[]
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, name])
  @@index([academicYearId, isActive])
}

model SchoolClass {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  name        String
  code        String
  level       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments ClassEnrollment[]
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  streams     Stream[]
  marks       SubjectMark[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
}

model Stream {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  classId     String            @db.Uuid
  name        String
  code        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments ClassEnrollment[]
  class       SchoolClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks       SubjectMark[]

  @@unique([classId, code])
  @@index([schoolId])
}

model Student {
  id               String            @id @default(uuid()) @db.Uuid
  schoolId         String            @db.Uuid
  admissionNumber  String
  firstName        String
  lastName         String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  enrollments      ClassEnrollment[]
  guardianContacts GuardianContact[]
  issuedReports    IssuedReport[]
  promotionActions PromotionAction[]
  credentials      StudentCredential[]
  wallet           StudentWallet?
  walletTransactions StudentWalletTransaction[]
  attendanceEvents StudentAttendanceEvent[]
  gateScans        NfcGateScan[]
  nfcTags          NfcTag[]
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks            SubjectMark[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, isActive])
}

model ClassEnrollment {
  id             String           @id @default(uuid()) @db.Uuid
  studentId      String           @db.Uuid
  academicYearId String           @db.Uuid
  termId         String           @db.Uuid
  classId        String           @db.Uuid
  streamId       String           @db.Uuid
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  enrolledAt     DateTime         @default(now())
  leftAt         DateTime?
  status         EnrollmentStatus @default(ACTIVE)
  schoolId       String           @db.Uuid
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          SchoolClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stream         Stream           @relation(fields: [streamId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term           Term             @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, termId])
  @@index([schoolId, academicYearId, termId, classId, streamId, isActive, status])
  @@index([schoolId, studentId, academicYearId, termId])
  @@index([academicYearId, termId, classId, streamId, isActive, status])
}

model GuardianContact {
  id                     String                 @id @default(uuid()) @db.Uuid
  schoolId               String                 @db.Uuid
  studentId              String                 @db.Uuid
  guardianName           String
  relationship           String
  phone                  String?
  email                  String?
  preferredContactMethod PreferredContactMethod @default(PHONE)
  isPrimary              Boolean                @default(false)
  canReceiveReports      Boolean                @default(true)
  notes                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  school                 School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student                Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianName, relationship])
  @@index([schoolId, studentId, isPrimary])
  @@index([studentId, canReceiveReports])
}

model Subject {
  id        String        @id @default(uuid()) @db.Uuid
  schoolId  String        @db.Uuid
  name      String
  code      String
  sortOrder Int
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks     SubjectMark[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId, isActive, sortOrder])
}

model SubjectMark {
  id             String           @id @default(uuid()) @db.Uuid
  schoolId       String           @db.Uuid
  studentId      String           @db.Uuid
  academicYearId String           @db.Uuid
  termId         String           @db.Uuid
  classId        String           @db.Uuid
  streamId       String           @db.Uuid
  subjectId      String           @db.Uuid
  assessmentType AssessmentType
  marks          Decimal          @db.Decimal(5, 2)
  status         MarkStatus       @default(DRAFT)
  comments       String?
  importBatchId  String?          @db.Uuid
  seedKey        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          SchoolClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  importBatch    MarkImportBatch? @relation(fields: [importBatchId], references: [id])
  stream         Stream           @relation(fields: [streamId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject        Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term           Term             @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, termId, assessmentType])
  @@index([schoolId, academicYearId, termId, classId, streamId, assessmentType, status])
  @@index([schoolId, studentId, academicYearId, termId, assessmentType])
  @@index([schoolId, subjectId, academicYearId, termId, assessmentType])
  @@index([importBatchId])
}

model MarkImportBatch {
  id        String          @id @default(uuid()) @db.Uuid
  schoolId  String          @db.Uuid
  status    ImportStatus
  source    String
  summary   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rows      MarkImportRow[]
  marks     SubjectMark[]

  @@index([schoolId, status, createdAt])
}

model MarkImportRow {
  id        String          @id @default(uuid()) @db.Uuid
  batchId   String          @db.Uuid
  rowNumber Int
  raw       Json
  isValid   Boolean
  errors    String[]
  createdAt DateTime        @default(now())
  batch     MarkImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowNumber])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @db.Uuid
  action        String
  correlationId String?
  details       Json?
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, action, createdAt])
  @@index([schoolId, correlationId])
}

model AppSetting {
  id         String   @id @default(uuid()) @db.Uuid
  schoolCode String   @unique
  sections   Json
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolCode])
}

model User {
  id                 String         @id @default(uuid()) @db.Uuid
  schoolId           String         @db.Uuid
  name               String
  email              String
  passwordHash       String
  role               UserRole       @default(ADMIN_OPERATOR)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  isPlatformOwner    Boolean        @default(false)
  mustChangePassword Boolean        @default(false)
  lastLoginAt        DateTime?
  issuedReports      IssuedReport[]
  studentCredentialsIssued StudentCredential[] @relation("StudentCredentialIssuedBy")
  walletTransactions StudentWalletTransaction[] @relation("StudentWalletTransactionCashier")
  gateScans          NfcGateScan[] @relation("NfcGateScanScannedBy")
  school             School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, email])
  @@index([schoolId, role])
  @@index([isPlatformOwner])
}

model SchoolSmartPagePlan {
  id                String   @id @default(uuid()) @db.Uuid
  schoolId          String   @unique @db.Uuid
  planName          String   @default("STANDARD")
  includedPages     Int      @default(5000)
  billingCycle      String   @default("ACADEMIC_YEAR")
  cycleStart        DateTime
  cycleEnd          DateTime
  usedPages         Int      @default(0)
  topUpPages        Int      @default(0)
  rolloverPages     Int      @default(0)
  status            String   @default("ACTIVE")
  allowHighAccuracy Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([schoolId, status])
}

model SmartPageLedger {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @db.Uuid
  jobId          String
  fileHash       String
  pagesCharged   Int      @default(0)
  creditsCharged Int      @default(0)
  operation      String   @default("EXTRACT")
  pagesProcessed Int      @default(0)
  priceUgx       Int      @default(0)
  action         String   @default("EXTRACT")
  reason         String   @default("")
  provider       String   @default("")
  model          String   @default("")
  extractionMode String   @default("balanced")
  status         String   @default("CHARGED")
  tokenUsage     Json?
  geminiCostEstimateUgx Int?
  marginEstimateUgx     Int?
  createdAt      DateTime @default(now())

  @@index([schoolId, fileHash, status])
  @@index([schoolId, createdAt])
}

model SmartPagePaymentRequest {
  id                 String   @id @default(uuid()) @db.Uuid
  schoolId           String   @db.Uuid
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  packageCode        String
  packageName        String
  credits            Int
  amountUgx          Int
  network            String
  merchantCode       String
  merchantName       String   @default("")
  paymentReference   String   @unique
  transactionId      String?
  payerPhone         String?
  proofScreenshotUrl String?
  status             String   @default("PENDING")
  adminNotes         String?
  confirmedByUserId  String?  @db.Uuid
  confirmedAt        DateTime?
  rejectedAt         DateTime?
  rejectedByUserId   String?  @db.Uuid
  telegramSentAt     DateTime?
  telegramError      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([network, transactionId])
  @@index([schoolId, status, createdAt])
  @@index([status, createdAt])
}

model StudentCredential {
  id                  String           @id @default(uuid()) @db.Uuid
  schoolId            String           @db.Uuid
  studentId           String           @db.Uuid
  type                CredentialType
  credentialUID       String
  scanToken           String?          @unique
  status              CredentialStatus @default(ACTIVE)
  issuedAt            DateTime         @default(now())
  deactivatedAt       DateTime?
  deactivatedReason   String?
  issuedById          String?          @db.Uuid
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  school              School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student             Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy            User?            @relation("StudentCredentialIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  walletTransactions  StudentWalletTransaction[]
  attendanceEvents    StudentAttendanceEvent[]
  gateScans           NfcGateScan[]

  @@unique([schoolId, type, credentialUID])
  @@index([schoolId])
  @@index([studentId])
  @@index([schoolId, status])
  @@index([schoolId, type, status])
}

model StudentWallet {
  id                  String              @id @default(uuid()) @db.Uuid
  schoolId            String              @db.Uuid
  studentId           String              @unique @db.Uuid
  balanceCents        Int                 @default(0)
  status              StudentWalletStatus @default(ACTIVE)
  frozenReason        String?
  pinHash             String?
  pinSetAt            DateTime?
  pinFailedAttempts   Int                 @default(0)
  pinLockedUntil      DateTime?
  pinLastVerifiedAt   DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions StudentWalletTransaction[]

  @@index([schoolId, status])
  @@index([schoolId, studentId])
}

model StudentWalletTransaction {
  id             String                @id @default(uuid()) @db.Uuid
  schoolId       String                @db.Uuid
  studentId      String                @db.Uuid
  walletId       String                @db.Uuid
  credentialId   String?               @db.Uuid
  cashierUserId  String?               @db.Uuid
  type              WalletTransactionType
  amountCents       Int
  balanceAfterCents Int?
  paymentMethod     String?
  reference         String?
  description       String?
  idempotencyKey    String?
  reversalOfId      String?               @db.Uuid
  createdAt         DateTime              @default(now())
  school            School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  wallet            StudentWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  credential        StudentCredential?    @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  cashier           User?                 @relation("StudentWalletTransactionCashier", fields: [cashierUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, idempotencyKey])
  @@index([schoolId, createdAt])
  @@index([schoolId, studentId, createdAt])
  @@index([schoolId, walletId, createdAt])
  @@index([schoolId, reversalOfId])
}

model StudentAttendanceEvent {
  id           String               @id @default(uuid()) @db.Uuid
  schoolId     String               @db.Uuid
  studentId    String               @db.Uuid
  credentialId String?              @db.Uuid
  direction    AttendanceDirection
  source       AttendanceScanSource @default(NFC_WRISTBAND)
  status       AttendanceScanStatus @default(VALID)
  reason       String?
  scannedAt    DateTime             @default(now())
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  credential   StudentCredential?   @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([schoolId, scannedAt])
  @@index([schoolId, studentId, scannedAt])
  @@index([schoolId, credentialId, scannedAt])
}

model NfcGateScan {
  id              String           @id @default(uuid()) @db.Uuid
  schoolId        String           @db.Uuid
  studentId       String?          @db.Uuid
  credentialId    String?          @db.Uuid
  scannedByUserId String?          @db.Uuid
  result          GateScanResult
  reason          String?
  scannedAt       DateTime         @default(now())
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  credential      StudentCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  scannedBy       User?            @relation("NfcGateScanScannedBy", fields: [scannedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, scannedAt])
  @@index([schoolId, studentId, scannedAt])
  @@index([schoolId, credentialId, scannedAt])
}

// Legacy DocumentCleanerJob remains in schema. Confirm no live data before safe removal migration.
model DocumentCleanerJob {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String?  @db.Uuid
  uploadedBy     String?
  documentType   String   @default("table")
  pageCount      Int      @default(1)
  provider       String   @default("")
  model          String   @default("")
  extractionMode String   @default("balanced")
  status         String   @default("PENDING")
  pagesCharged   Int      @default(0)
  confidence     Float    @default(0)
  fileHash       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([schoolId, fileHash])
  @@index([schoolId, status, createdAt])
}

model PromotionBatch {
  id             String              @id @default(uuid()) @db.Uuid
  schoolId       String              @db.Uuid
  academicYearId String              @db.Uuid
  termId         String              @db.Uuid
  assessmentType String
  classId        String?             @db.Uuid
  streamId       String?             @db.Uuid
  scoreThreshold Float               @default(40)
  status         PromotionBatchStatus @default(APPLIED)
  appliedAt      DateTime            @default(now())
  appliedByName  String?
  reversedAt     DateTime?
  reversedByName String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actions        PromotionAction[]

  @@index([schoolId, status, createdAt])
  @@index([schoolId, academicYearId, termId])
}

model PromotionAction {
  id               String              @id @default(uuid()) @db.Uuid
  batchId          String              @db.Uuid
  schoolId         String              @db.Uuid
  studentId        String              @db.Uuid
  studentName      String
  fromEnrollmentId String              @db.Uuid
  toEnrollmentId   String?             @db.Uuid
  fromClassName    String
  fromStreamName   String
  toClassName      String?
  toStreamName     String?
  averageScore     Float?
  decision         PromotionDecision
  status           PromotionActionStatus @default(APPLIED)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  batch            PromotionBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  school           School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student          Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([schoolId, studentId, status])
}

model IssuedReport {
  id                 String             @id @default(uuid()) @db.Uuid
  schoolId           String             @db.Uuid
  studentId          String             @db.Uuid
  academicYear       String
  term               String
  assessmentType     String
  reportSnapshotJson Json
  referenceCode      String             @unique
  parentAccessToken  String             @unique
  status             IssuedReportStatus @default(ISSUED)
  issuedAt           DateTime           @default(now())
  issuedById         String?            @db.Uuid
  issuedByName       String?
  viewedAt           DateTime?
  downloadedAt       DateTime?
  sentAt             DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  issuedBy           User?              @relation(fields: [issuedById], references: [id])
  school             School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student            Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([parentAccessToken])
  @@index([referenceCode])
  @@index([schoolId, status])
  @@index([studentId, status])
}

model ReportLabSubscription {
  id                 String                   @id @default(uuid()) @db.Uuid
  schoolId           String                   @unique @db.Uuid
  planCode           String
  billingCycle       SubscriptionBillingCycle @default(YEAR)
  studentLimit       Int?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  status             SubscriptionStatus       @default(ACTIVE)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  invoices           ReportLabInvoice[]
  school             School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

model ReportLabInvoice {
  id             String                @id @default(uuid()) @db.Uuid
  subscriptionId String                @db.Uuid
  setupFeeUgx    Int                   @default(0)
  amountUgx      Int
  totalUgx       Int
  status         InvoiceStatus         @default(UNPAID)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  subscription   ReportLabSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
}

model Creator {
  id            String               @id @default(uuid()) @db.Uuid
  type          CreatorType
  email         String               @unique
  name          String
  schoolId      String?              @db.Uuid
  passwordHash  String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workflows     AutomationWorkflow[]
  bulkJobs      BulkGenerationJob[]
  collections   Collection[]
  preferences   CreatorPreference[]
  notifications Notification[]
  searchIndexes SearchIndex[]
  documents     SmartDocument[]

  @@index([email])
  @@index([schoolId])
  @@index([type])
}

model SmartDocument {
  id                    String                  @id @default(uuid()) @db.Uuid
  creatorId             String                  @db.Uuid
  schoolId              String?                 @db.Uuid
  title                 String
  vertical              SmartDocumentVertical   @default(SCHOOL)
  extractedKnowledge    Json?
  activeVersionId       String?                 @db.Uuid
  status                DocumentStatus          @default(DRAFT)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  extractionStatus      String                  @default("IDLE")
  extractionError       String?
  extractionStartedAt   DateTime?
  extractionCompletedAt DateTime?
  analytics             DocumentAnalytics?
  sourceFiles           DocumentSourceFile[]
  versions              DocumentVersion[]
  published             PublishedDocument?
  creator               Creator                 @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, status, createdAt])
  @@index([creatorId, extractionStatus, updatedAt])
  @@index([creatorId, vertical, status, createdAt])
  @@index([creatorId, vertical, extractionStatus, updatedAt])
  @@index([schoolId, status, createdAt])
  @@index([schoolId, extractionStatus, updatedAt])
  @@index([schoolId, vertical, status, createdAt])
  @@index([schoolId, vertical, extractionStatus, updatedAt])
}

model DocumentVersion {
  id             String        @id @default(uuid()) @db.Uuid
  documentId     String        @db.Uuid
  parentId       String?       @db.Uuid
  instruction    String?
  schema         Json
  componentTree  Json
  renderSettings Json          @default("{}")
  createdAt      DateTime      @default(now())
  document       SmartDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model DocumentSourceFile {
  id                    String        @id @default(uuid()) @db.Uuid
  documentId            String        @db.Uuid
  originalName          String
  mimeType              String
  sizeBytes             Int?
  geminiFileUri         String?
  extractedContent      Json?
  createdAt             DateTime      @default(now())
  originalData          Bytes?
  processedData         Bytes?
  processedMimeType     String?
  ocrQuality            Json?
  status                String        @default("UPLOADED")
  extractionError       String?
  extractionStartedAt   DateTime?
  extractionCompletedAt DateTime?
  fileHash              String?
  document              SmartDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status, createdAt])
  @@index([fileHash])
}

model PublishedDocument {
  id            String        @id @default(uuid()) @db.Uuid
  documentId    String        @unique @db.Uuid
  token         String        @unique
  passwordHash  String?
  expiresAt     DateTime?
  viewCount     Int           @default(0)
  downloadCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  document      SmartDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Collection {
  id        String              @id @default(uuid()) @db.Uuid
  creatorId String              @db.Uuid
  name      String
  type      CollectionType      @default(CUSTOM)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  bulkJobs  BulkGenerationJob[]
  creator   Creator             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  records   CollectionRecord[]

  @@index([creatorId])
}

model CollectionRecord {
  id           String          @id @default(uuid()) @db.Uuid
  collectionId String          @db.Uuid
  data         Json
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  outputs      BulkJobOutput[]
  collection   Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, sortOrder])
}

model BulkGenerationJob {
  id               String          @id @default(uuid()) @db.Uuid
  creatorId        String          @db.Uuid
  collectionId     String          @db.Uuid
  intent           String
  templateSchema   Json?
  status           BulkJobStatus   @default(PENDING)
  totalRecords     Int             @default(0)
  processedRecords Int             @default(0)
  failedRecords    Int             @default(0)
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  collection       Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  creator          Creator         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  outputs          BulkJobOutput[]

  @@index([creatorId, status])
  @@index([status, createdAt])
}

model BulkJobOutput {
  id           String            @id @default(uuid()) @db.Uuid
  jobId        String            @db.Uuid
  recordId     String            @db.Uuid
  documentId   String?           @db.Uuid
  publishToken String?
  status       String            @default("PENDING")
  error        String?
  createdAt    DateTime          @default(now())
  job          BulkGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  record       CollectionRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([recordId])
}

model CreatorPreference {
  id        String   @id @default(uuid()) @db.Uuid
  creatorId String   @db.Uuid
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, key])
  @@index([creatorId])
}

model AutomationWorkflow {
  id        String    @id @default(uuid()) @db.Uuid
  creatorId String    @db.Uuid
  name      String
  trigger   String
  actions   Json
  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  creator   Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, isActive])
  @@index([trigger, isActive])
}

model SearchIndex {
  id             String   @id @default(uuid()) @db.Uuid
  creatorId      String   @db.Uuid
  entityType     String
  entityId       String
  title          String?
  searchableText String
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  creator        Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([creatorId, entityType])
  @@index([creatorId, updatedAt])
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  creatorId String    @db.Uuid
  type      String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  creator   Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, readAt, createdAt])
  @@index([creatorId, type])
}

model DocumentAnalytics {
  id           String        @id @default(uuid()) @db.Uuid
  documentId   String        @unique @db.Uuid
  views        Int           @default(0)
  downloads    Int           @default(0)
  shares       Int           @default(0)
  visitors     Int           @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  document     SmartDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([views])
  @@index([downloads])
  @@index([updatedAt])
}

