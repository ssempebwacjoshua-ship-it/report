}

model NfcTag {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @db.Uuid
  batchId        String?   @db.Uuid
  publicCode     String    @unique
  physicalUid    String?
  tagMode        String    @default("URL") // "URL" | "UID" | "TEXT"
  label          String?
  type           String    @default("STUDENT")
  purpose        String    @default("STUDENT")
  status         String    @default("UNASSIGNED")
  // status lifecycle:
  // URL tags:  GENERATED → WRITTEN → VERIFIED → UNALLOCATED → ASSIGNED | DISABLED | LOST
  // UID tags:  REGISTERED → VERIFIED → UNALLOCATED → ASSIGNED | DISABLED | LOST
  // Legacy:    UNASSIGNED (= UNALLOCATED), ASSIGNED, DISABLED
  studentId      String?   @db.Uuid
  createdById    String?   @db.Uuid
  writtenUrl     String?
  writtenPayload String?
  issuedAt       DateTime?
  writtenAt      DateTime?
  verifiedAt     DateTime?
  assignedAt     DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  batch     NfcTagBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  student   Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  tapEvents NfcTapEvent[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, studentId])
  @@index([schoolId, batchId])
  @@index([schoolId, tagMode, status])
  @@index([schoolId, physicalUid], map: "NfcTag_schoolId_physicalUid_idx")
}

model NfcTapEvent {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String?  @db.Uuid
  tagId      String?  @db.Uuid
  studentId  String?  @db.Uuid
  publicCode String
  result     String
  userAgent  String?
  ipHash     String?
  createdAt  DateTime @default(now())

  tag NfcTag? @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@index([publicCode])
  @@index([tagId, createdAt])
  @@index([schoolId, publicCode, createdAt], map: "NfcTapEvent_school_publicCode_createdAt_idx")
}

model CommunicationCampaign {
  id                      String                      @id @default(uuid()) @db.Uuid
  schoolId                String                      @db.Uuid
  type                    CommunicationType
  title                   String
  status                  CommunicationCampaignStatus @default(DRAFT)
  priority                String                      @default("NORMAL")
  contentVersion          Int                         @default(1)
  createdByUserId         String?                     @db.Uuid
  approvedByUserId        String?                     @db.Uuid
  approvedAt              DateTime?
  scheduledAt             DateTime?
  sendingStartedAt        DateTime?
  completedAt             DateTime?
  cancelledAt             DateTime?
  replyPolicy             String                      @default("NONE")
  acknowledgementRequired Boolean                     @default(false)
  metadataJson            Json?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  school            School                          @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  createdBy         User?                           @relation("CommunicationCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy        User?                           @relation("CommunicationCampaignApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  contents          CommunicationContent[]
  audience          CommunicationAudience?
  audienceSnapshots CommunicationAudienceSnapshot[]
  recipients        CommunicationRecipient[]
  deliveries        CommunicationDelivery[]
  approvals         CommunicationApproval[]
  usageRecords      CommunicationUsageRecord[]

  @@index([schoolId, status, createdAt])
  @@index([schoolId, type, createdAt])
}

model CommunicationContent {
  id                    String   @id @default(uuid()) @db.Uuid
  campaignId            String   @db.Uuid
  version               Int
  subject               String?
  body                  String
  shortBody             String?
  callToActionLabel     String?
  callToActionUrl       String?
  templateVariablesJson Json?
  createdByUserId       String?  @db.Uuid
  createdAt             DateTime @default(now())

  campaign  CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  createdBy User?                 @relation("CommunicationContentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([campaignId, version])
  @@index([campaignId, createdAt])
}

model CommunicationAudience {
  id                  String   @id @default(uuid()) @db.Uuid
  campaignId          String   @unique @db.Uuid
  definitionJson      Json
  estimatedRecipients Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
}

model CommunicationAudienceSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  campaignId      String   @db.Uuid
  snapshotVersion Int
  recipientCount  Int      @default(0)
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())

  campaign   CommunicationCampaign    @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  createdBy  User?                    @relation("CommunicationAudienceSnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  recipients CommunicationRecipient[]

  @@unique([campaignId, snapshotVersion])
  @@index([campaignId, createdAt])
}

model CommunicationRecipient {
  id                  String                       @id @default(uuid()) @db.Uuid
  schoolId            String                       @db.Uuid
  campaignId          String                       @db.Uuid
  audienceSnapshotId  String                       @db.Uuid
  guardianId          String?                      @db.Uuid
  studentId           String?                      @db.Uuid
  staffUserId         String?                      @db.Uuid
  displayName         String
  relationship        String?
  phoneE164           String?
  email               String?
  preferredChannel    CommunicationChannel?
  status              CommunicationRecipientStatus @default(PENDING)
  warningCodesJson    Json?
  blockedReasonCode   String?
  personalisationJson Json?
  acknowledgedAt      DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  school           School                        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  campaign         CommunicationCampaign         @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  audienceSnapshot CommunicationAudienceSnapshot @relation(fields: [audienceSnapshotId], references: [id], onDelete: Restrict)
  guardian         GuardianContact?              @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  student          Student?                      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  deliveries       CommunicationDelivery[]

  @@index([schoolId, campaignId, status])
  @@index([schoolId, studentId])
  @@index([schoolId, guardianId])
}

model CommunicationDelivery {
  id                   String                      @id @default(uuid()) @db.Uuid
  schoolId             String                      @db.Uuid
  campaignId           String                      @db.Uuid
  recipientId          String                      @db.Uuid
  channel              CommunicationChannel
  provider             String                      @default("DRY_RUN")
  status               CommunicationDeliveryStatus @default(PENDING)
  contentVersion       Int
  idempotencyKey       String                      @unique
  renderedContentHash  String?
  providerMessageId    String?
  queuedAt             DateTime?
  submittedAt          DateTime?
  acceptedAt           DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  lastErrorCode        String?
  lastErrorMessageSafe String?
  attemptCount         Int                         @default(0)
  nextRetryAt          DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  school       School                         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  campaign     CommunicationCampaign          @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  recipient    CommunicationRecipient         @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  attempts     CommunicationDeliveryAttempt[]
  usageRecords CommunicationUsageRecord[]

  @@unique([campaignId, recipientId, channel, contentVersion])
  @@index([schoolId, campaignId, status])
  @@index([schoolId, status, nextRetryAt])
}

model CommunicationDeliveryAttempt {
  id                   String                     @id @default(uuid()) @db.Uuid
  deliveryId           String                     @db.Uuid
  attemptNumber        Int
  provider             String
  status               CommunicationAttemptStatus
  requestId            String?
  providerMessageId    String?
  providerResponseCode String?
  errorCode            String?
  errorMessageSafe     String?
  startedAt            DateTime                   @default(now())
  completedAt          DateTime?
  createdAt            DateTime                   @default(now())

  delivery CommunicationDelivery @relation(fields: [deliveryId], references: [id], onDelete: Restrict)

  @@unique([deliveryId, attemptNumber])
  @@index([deliveryId, createdAt])
}

model CommunicationApproval {
  id                String                      @id @default(uuid()) @db.Uuid
  campaignId        String                      @db.Uuid
  requiredRole      String
  requestedByUserId String?                     @db.Uuid
  requestedAt       DateTime                    @default(now())
  reviewedByUserId  String?                     @db.Uuid
  reviewedAt        DateTime?
  status            CommunicationApprovalStatus @default(PENDING)
  comment           String?
  createdAt         DateTime                    @default(now())

  campaign    CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  requestedBy User?                 @relation("CommunicationApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  reviewedBy  User?                 @relation("CommunicationApprovalReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
}

model CommunicationTemplate {
  id                   String               @id @default(uuid()) @db.Uuid
  schoolId             String               @db.Uuid
  channel              CommunicationChannel
  communicationType    CommunicationType
