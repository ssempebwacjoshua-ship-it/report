enum CommunicationCampaignStatus {
  DRAFT
  VALIDATING
  VALIDATION_FAILED
  READY_FOR_APPROVAL
  APPROVAL_PENDING
  APPROVED
  SCHEDULED
  QUEUED
  SENDING
  PARTIALLY_DELIVERED
  DELIVERED
  FAILED
  PAUSED
  CANCELLED
}

enum CommunicationRecipientStatus {
