generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                           String                        @id @default(uuid()) @db.Uuid
  code                         String                        @unique
  name                         String
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  phone                        String?
  email                        String?
  address                      String?
  logoUrl                      String?
  timezone                     String                        @default("Africa/Kampala")
  brandingMode                 String                        @default("PLATFORM_DEFAULTS")
  isActive                     Boolean                       @default(true)
  academicYears                AcademicYear[]
  auditLogs                    AuditLog[]
  enrollments                  ClassEnrollment[]
  guardianContacts             GuardianContact[]
  issuedReports                IssuedReport[]
  imports                      MarkImportBatch[]
  subscription                 ReportLabSubscription?
  classes                      SchoolClass[]
  streams                      Stream[]
  students                     Student[]
  subjects                     Subject[]
  users                        User[]
  smartPagePayments            SmartPagePaymentRequest[]
  promotionBatches             PromotionBatch[]
  promotionActions             PromotionAction[]
  studentCredentials           StudentCredential[]
  studentWallets               StudentWallet[]
  studentWalletTransactions    StudentWalletTransaction[]
  nfcPolicy                    SchoolNfcPolicy?
  studentFeeHolds              StudentFeeHold[]
  studentGateHolds             StudentGateHold[]
  canteenReconciliations       CanteenReconciliation[]
  studentAttendanceEvents      StudentAttendanceEvent[]
  dailyAttendances             DailyAttendance[]
  campusMovementEvents         CampusMovementEvent[]
  classroomAttendanceEvents    ClassroomAttendanceEvent[]
  nfcGateScans                 NfcGateScan[]
  nfcTags                      NfcTag[]
  nfcTagBatches                NfcTagBatch[]
  nfcOfflineDevices            NfcOfflineDevice[]
  nfcOfflineSyncBatches        NfcOfflineSyncBatch[]
  communicationCampaigns       CommunicationCampaign[]
  communicationRecipients      CommunicationRecipient[]
  communicationDeliveries      CommunicationDelivery[]
  communicationTemplates       CommunicationTemplate[]
  communicationConsents        CommunicationConsent[]
  communicationUsageRecords    CommunicationUsageRecord[]
  communicationChannelSettings CommunicationChannelSetting[]
  authTokens                   AuthToken[]
}

model AcademicYear {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  name        String
  startsOn    DateTime
  endsOn      DateTime
  isActive    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
  marks       SubjectMark[]
  terms       Term[]

  @@unique([schoolId, name])
  @@index([schoolId, isActive])
}

model Term {
  id             String            @id @default(uuid()) @db.Uuid
  academicYearId String            @db.Uuid
  name           String
  startsOn       DateTime
  endsOn         DateTime
  isActive       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  enrollments    ClassEnrollment[]
  marks          SubjectMark[]
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, name])
  @@index([academicYearId, isActive])
}

model SchoolClass {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  name        String
  code        String
  level       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments ClassEnrollment[]
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  streams     Stream[]
  marks       SubjectMark[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
}

model Stream {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @db.Uuid
  classId     String            @db.Uuid
  name        String
  code        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments ClassEnrollment[]
  class       SchoolClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks       SubjectMark[]

  @@unique([classId, code])
  @@index([schoolId])
  @@index([schoolId, classId, code], map: "Stream_schoolId_classId_code_idx")
}

model Student {
  id                        String                     @id @default(uuid()) @db.Uuid
  schoolId                  String                     @db.Uuid
  admissionNumber           String
  firstName                 String
  lastName                  String
  attendanceProfile         AttendanceProfile          @default(DAY_SCHOLAR)
  studentType               StudentType?
  passportPhotoUrl          String?
  passportPhotoUpdatedAt    DateTime?
  isActive                  Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  enrollments               ClassEnrollment[]
  guardianContacts          GuardianContact[]
  issuedReports             IssuedReport[]
  communicationRecipients   CommunicationRecipient[]
  promotionActions          PromotionAction[]
  credentials               StudentCredential[]
  wallet                    StudentWallet?
  walletTransactions        StudentWalletTransaction[]
  feeHolds                  StudentFeeHold[]
  gateHolds                 StudentGateHold[]
  attendanceEvents          StudentAttendanceEvent[]
  dailyAttendances          DailyAttendance[]
  campusMovementEvents      CampusMovementEvent[]
  classroomAttendanceEvents ClassroomAttendanceEvent[]
  gateScans                 NfcGateScan[]
  nfcTags                   NfcTag[]
  school                    School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks                     SubjectMark[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, isActive])
  @@index([schoolId, admissionNumber, isActive], map: "Student_schoolId_admissionNumber_isActive_idx")
}

model ClassEnrollment {
  id             String           @id @default(uuid()) @db.Uuid
  studentId      String           @db.Uuid
  academicYearId String           @db.Uuid
  termId         String           @db.Uuid
  classId        String           @db.Uuid
  streamId       String           @db.Uuid
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  enrolledAt     DateTime         @default(now())
  leftAt         DateTime?
  status         EnrollmentStatus @default(ACTIVE)
  schoolId       String           @db.Uuid
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          SchoolClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stream         Stream           @relation(fields: [streamId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term           Term             @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, termId])
  @@index([schoolId, academicYearId, termId, classId, streamId, isActive, status])
  @@index([schoolId, studentId, academicYearId, termId])
  @@index([academicYearId, termId, classId, streamId, isActive, status])
}

model GuardianContact {
  id                      String                   @id @default(uuid()) @db.Uuid
  schoolId                String                   @db.Uuid
  studentId               String                   @db.Uuid
  guardianName            String
  relationship            String
  phone                   String?
  email                   String?
  preferredContactMethod  PreferredContactMethod   @default(PHONE)
  isPrimary               Boolean                  @default(false)
  canReceiveReports       Boolean                  @default(true)
  notes                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  school                  School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student                 Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  communicationRecipients CommunicationRecipient[]
  communicationConsents   CommunicationConsent[]

  @@unique([studentId, guardianName, relationship])
  @@index([schoolId, studentId, isPrimary])
  @@index([studentId, canReceiveReports])
}

model Subject {
  id                 String                    @id @default(uuid()) @db.Uuid
  schoolId           String                    @db.Uuid
  name               String
  code               String
  sortOrder          Int
  isActive           Boolean                   @default(true)
  componentFinalMode SubjectComponentFinalMode @default(AVERAGE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  school             School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  components         SubjectComponent[]
  marks              SubjectMark[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId, isActive, sortOrder])
}

model SubjectComponent {
  id        String        @id @default(uuid()) @db.Uuid
  schoolId  String        @db.Uuid
  subjectId String        @db.Uuid
  name      String
  code      String
  sortOrder Int
  weight    Decimal?      @db.Decimal(5, 2)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  subject   Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marks     SubjectMark[]

  @@unique([subjectId, name])
  @@unique([subjectId, code])
  @@index([schoolId, subjectId, isActive, sortOrder])
}

model SubjectMark {
  id             String            @id @default(uuid()) @db.Uuid
  schoolId       String            @db.Uuid
  studentId      String            @db.Uuid
  academicYearId String            @db.Uuid
  termId         String            @db.Uuid
  classId        String            @db.Uuid
  streamId       String            @db.Uuid
  subjectId      String            @db.Uuid
  componentId    String?           @db.Uuid
  componentKey   String            @default("")
  assessmentType AssessmentType
  marks          Decimal           @db.Decimal(5, 2)
  status         MarkStatus        @default(DRAFT)
  comments       String?
  importBatchId  String?           @db.Uuid
  seedKey        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          SchoolClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  importBatch    MarkImportBatch?  @relation(fields: [importBatchId], references: [id])
  stream         Stream            @relation(fields: [streamId], references: [id], onDelete: Cascade)
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject        Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  component      SubjectComponent? @relation(fields: [componentId], references: [id], onDelete: Cascade)
  term           Term              @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, componentKey, termId, assessmentType])
  @@index([schoolId, academicYearId, termId, classId, streamId, assessmentType, status])
  @@index([schoolId, studentId, academicYearId, termId, assessmentType])
  @@index([schoolId, subjectId, academicYearId, termId, assessmentType])
  @@index([schoolId, subjectId, componentId, academicYearId, termId, assessmentType])
  @@index([schoolId, studentId, subjectId, termId, assessmentType], map: "SubjectMark_school_student_subject_term_type_idx")
  @@index([importBatchId])
}

model MarkImportBatch {
  id        String          @id @default(uuid()) @db.Uuid
  schoolId  String          @db.Uuid
  status    ImportStatus
  source    String
  summary   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rows      MarkImportRow[]
  marks     SubjectMark[]

  @@index([schoolId, status, createdAt])
}

model MarkImportRow {
  id        String          @id @default(uuid()) @db.Uuid
  batchId   String          @db.Uuid
  rowNumber Int
  raw       Json
  isValid   Boolean
  errors    String[]
  createdAt DateTime        @default(now())
  batch     MarkImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowNumber])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @db.Uuid
  action        String
  correlationId String?
  details       Json?
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, action, createdAt])
  @@index([schoolId, correlationId])
  @@index([schoolId, createdAt], map: "AuditLog_schoolId_createdAt_idx")
}

model PlatformSupportSession {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @db.Uuid
  ownerUserId String
  mode        String    @default("READ_ONLY")
  status      String    @default("ACTIVE")
  reason      String?
  expiresAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId, status, expiresAt])
  @@index([ownerUserId, createdAt])
}

model SchoolFeatureFlag {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  feature         String
  enabled         Boolean  @default(false)
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([schoolId, feature])
  @@index([schoolId, enabled])
}

model AppSetting {
  id         String   @id @default(uuid()) @db.Uuid
  schoolCode String   @unique
  sections   Json
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolCode])
}

model User {
  id                              String                          @id @default(uuid()) @db.Uuid
  schoolId                        String                          @db.Uuid
  name                            String
  email                           String
  passwordHash                    String
  role                            UserRole                        @default(ADMIN_OPERATOR)
  isActive                        Boolean                         @default(true)
  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  isPlatformOwner                 Boolean                         @default(false)
  mustChangePassword              Boolean                         @default(false)
  lastLoginAt                     DateTime?
  tokenVersion                    Int                             @default(0)
  issuedReports                   IssuedReport[]
  studentCredentialsIssued        StudentCredential[]             @relation("StudentCredentialIssuedBy")
  walletTransactions              StudentWalletTransaction[]      @relation("StudentWalletTransactionCashier")
  gateScans                       NfcGateScan[]                   @relation("NfcGateScanScannedBy")
  nfcPoliciesUpdated              SchoolNfcPolicy[]               @relation("SchoolNfcPolicyUpdatedBy")
  communicationCampaignsCreated   CommunicationCampaign[]         @relation("CommunicationCampaignCreatedBy")
  communicationCampaignsApproved  CommunicationCampaign[]         @relation("CommunicationCampaignApprovedBy")
  communicationContentsCreated    CommunicationContent[]          @relation("CommunicationContentCreatedBy")
  communicationSnapshotsCreated   CommunicationAudienceSnapshot[] @relation("CommunicationAudienceSnapshotCreatedBy")
  communicationApprovalsRequested CommunicationApproval[]         @relation("CommunicationApprovalRequestedBy")
  communicationApprovalsReviewed  CommunicationApproval[]         @relation("CommunicationApprovalReviewedBy")
  communicationConsentsRecorded   CommunicationConsent[]          @relation("CommunicationConsentRecordedBy")
  feeHoldsCreated                 StudentFeeHold[]                @relation("StudentFeeHoldCreatedBy")
  feeHoldsCleared                 StudentFeeHold[]                @relation("StudentFeeHoldClearedBy")
  canteenReconciliationCashiers   CanteenReconciliation[]         @relation("CanteenReconciliationCashier")
  canteenReconciliationOperators  CanteenReconciliation[]         @relation("CanteenReconciliationOperator")
  submittedCanteenReconciliations CanteenReconciliation[]         @relation("CanteenReconciliationSubmittedBy")
  approvedCanteenReconciliations  CanteenReconciliation[]         @relation("CanteenReconciliationApprovedBy")
  authTokens                      AuthToken[]
  school                          School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, email])
  @@index([schoolId, role])
  @@index([isPlatformOwner])
}

model AuthToken {
  id                 String        @id @default(uuid()) @db.Uuid
  schoolId           String        @db.Uuid
  userId             String        @db.Uuid
  type               AuthTokenType
  tokenHash          String        @unique
  expiresAt          DateTime
  usedAt             DateTime?
  revokedAt          DateTime?
  requestedIp        String?
  requestedUserAgent String?
  resendMessageId    String?
  deliveryStatus     String        @default("PENDING")
  deliveryErrorCode  String?
  createdAt          DateTime      @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([schoolId, userId, type, expiresAt])
  @@index([type, expiresAt])
  @@index([schoolId, deliveryStatus, createdAt])
}

model SchoolSmartPagePlan {
  id                String   @id @default(uuid()) @db.Uuid
  schoolId          String   @unique @db.Uuid
  planName          String   @default("STANDARD")
  includedPages     Int      @default(5000)
  billingCycle      String   @default("ACADEMIC_YEAR")
  cycleStart        DateTime
  cycleEnd          DateTime
  usedPages         Int      @default(0)
  topUpPages        Int      @default(0)
  rolloverPages     Int      @default(0)
  status            String   @default("ACTIVE")
  allowHighAccuracy Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([schoolId, status])
}

model SmartPageLedger {
  id                    String   @id @default(uuid()) @db.Uuid
  schoolId              String   @db.Uuid
  jobId                 String
  fileHash              String
  pagesCharged          Int      @default(0)
  creditsCharged        Int      @default(0)
  operation             String   @default("EXTRACT")
  pagesProcessed        Int      @default(0)
  priceUgx              Int      @default(0)
  action                String   @default("EXTRACT")
  reason                String   @default("")
  provider              String   @default("")
  model                 String   @default("")
  extractionMode        String   @default("balanced")
  status                String   @default("CHARGED")
  tokenUsage            Json?
  geminiCostEstimateUgx Int?
  marginEstimateUgx     Int?
  createdAt             DateTime @default(now())

  @@index([schoolId, fileHash, status])
  @@index([schoolId, createdAt])
}

model SmartPagePaymentRequest {
  id                 String    @id @default(uuid()) @db.Uuid
  schoolId           String    @db.Uuid
  school             School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  packageCode        String
  packageName        String
  credits            Int
  amountUgx          Int
  network            String
  merchantCode       String
  merchantName       String    @default("")
  paymentReference   String    @unique
  transactionId      String?
  payerPhone         String?
  proofScreenshotUrl String?
  status             String    @default("PENDING")
  adminNotes         String?
  confirmedByUserId  String?   @db.Uuid
  confirmedAt        DateTime?
  rejectedAt         DateTime?
  rejectedByUserId   String?   @db.Uuid
  telegramSentAt     DateTime?
  telegramError      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([network, transactionId])
  @@index([schoolId, status, createdAt])
  @@index([status, createdAt])
}

model StudentCredential {
  id                 String                     @id @default(uuid()) @db.Uuid
  schoolId           String                     @db.Uuid
  studentId          String                     @db.Uuid
  type               CredentialType
  credentialUID      String
  scanToken          String?                    @unique
  status             CredentialStatus           @default(ACTIVE)
  issuedAt           DateTime                   @default(now())
  deactivatedAt      DateTime?
  deactivatedReason  String?
  issuedById         String?                    @db.Uuid
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student            Student                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy           User?                      @relation("StudentCredentialIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  walletTransactions StudentWalletTransaction[]
  attendanceEvents   StudentAttendanceEvent[]
  gateScans          NfcGateScan[]

  @@unique([schoolId, type, credentialUID])
  @@index([schoolId])
  @@index([studentId])
  @@index([schoolId, status])
  @@index([schoolId, type, status])
  @@index([schoolId, credentialUID], map: "StudentCredential_schoolId_credentialUID_idx")
}

model StudentWallet {
  id                String                     @id @default(uuid()) @db.Uuid
  schoolId          String                     @db.Uuid
  studentId         String                     @unique @db.Uuid
  balanceCents      Int                        @default(0)
  status            StudentWalletStatus        @default(ACTIVE)
  frozenReason      String?
  pinHash           String?
  pinSetAt          DateTime?
  pinFailedAttempts Int                        @default(0)
  pinLockedUntil    DateTime?
  pinLastVerifiedAt DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  school            School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions      StudentWalletTransaction[]

  @@index([schoolId, status])
  @@index([schoolId, studentId])
}

model StudentWalletTransaction {
  id                String                @id @default(uuid()) @db.Uuid
  schoolId          String                @db.Uuid
  studentId         String                @db.Uuid
  walletId          String                @db.Uuid
  credentialId      String?               @db.Uuid
  cashierUserId     String?               @db.Uuid
  type              WalletTransactionType
  amountCents       Int
  balanceAfterCents Int?
  paymentMethod     String?
  reference         String?
  description       String?
  idempotencyKey    String?
  reversalOfId      String?               @db.Uuid
  createdAt         DateTime              @default(now())
  school            School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  wallet            StudentWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  credential        StudentCredential?    @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  cashier           User?                 @relation("StudentWalletTransactionCashier", fields: [cashierUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, idempotencyKey])
  @@index([schoolId, createdAt])
  @@index([schoolId, studentId, createdAt])
  @@index([schoolId, walletId, createdAt])
  @@index([schoolId, reversalOfId])
}

model SchoolNfcPolicy {
  id                              String                 @id @default(uuid()) @db.Uuid
  schoolId                        String                 @unique @db.Uuid
  feeDefaulterBlockingEnabled     Boolean                @default(false)
  feeDefaulterBlockScope          FeeDefaulterBlockScope @default(DAY_SCHOLARS_ONLY)
  attendanceTapInCutoffEnabled    Boolean                @default(false)
  tapInCutoffTime                 String?
  cutoffLateAction                AttendanceLateAction   @default(BLOCK_AND_MARK_ABSENT)
  timezone                        String                 @default("Africa/Kampala")
  duplicateWindowSeconds          Int                    @default(60)
  gateArrivalStart                String                 @default("05:30")
  gateArrivalLateAfter            String                 @default("08:00")
  gateArrivalEnd                  String                 @default("10:00")
  morningClassroomStart           String                 @default("06:30")
  morningClassroomEnd             String                 @default("10:00")
  gateDepartureStart              String                 @default("14:00")
  gateDepartureEnd                String                 @default("19:00")
  nightPrepStart                  String                 @default("18:30")
  nightPrepEnd                    String                 @default("22:30")
  nightPrepBoardingOnly           Boolean                @default(true)
  allowAutomaticCheckout          Boolean                @default(false)
  recordUnclassifiedScans         Boolean                @default(true)
  feeGatePolicyEnabled            Boolean                @default(false)
  gateOfflineEnabled              Boolean                @default(false)
  canteenOfflineEnabled           Boolean                @default(false)
  gateSnapshotValidHours          Int                    @default(24)
  canteenSnapshotValidHours       Int                    @default(12)
  maxOfflineSpendPerStudentPerDay Int                    @default(5000)
  maxOfflineSpendPerTransaction   Int                    @default(2000)
  maxOfflineSpendPerDeviceSession Int                    @default(100000)
  unknownCardOfflinePolicy        String                 @default("DENY")
  frozenCardOfflinePolicy         String                 @default("DENY")
  deactivatedCardOfflinePolicy    String                 @default("DENY")
  offlineConflictPolicy           String                 @default("ALLOW_AND_FLAG")
  createdAt                       DateTime               @default(now())
  updatedAt                       DateTime               @updatedAt
  updatedByUserId                 String?                @db.Uuid

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedBy User?  @relation("SchoolNfcPolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
}

model StudentFeeHold {
  id              String               @id @default(uuid()) @db.Uuid
  schoolId        String               @db.Uuid
  studentId       String               @db.Uuid
  status          StudentFeeHoldStatus @default(ACTIVE)
  reason          String?
  balanceDueCents Int?
  effectiveFrom   DateTime?
  clearedAt       DateTime?
  createdByUserId String?              @db.Uuid
  clearedByUserId String?              @db.Uuid
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("StudentFeeHoldCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  clearedBy User?   @relation("StudentFeeHoldClearedBy", fields: [clearedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, studentId, status])
  @@index([schoolId, status, createdAt])
}

