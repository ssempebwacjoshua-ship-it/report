DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_connect_reports_lab?schema=public"
PORT=4300
VITE_API_BASE_URL="http://localhost:4300"
CLIENT_ORIGIN="http://localhost:5173"
APP_BASE_URL="http://localhost:5173"
APP_PUBLIC_URL="https://ssamenj.online/report-lab"
# Optional aliases used by auth email/link helpers and deployment docs.
APP_URL="https://ssamenj.online/report-lab"
PUBLIC_APP_URL="https://ssamenj.online/report-lab"
PUBLIC_SITE_URL="https://ssamenj.online"
PUBLIC_COMPANY_LOGO_URL="https://ssamenj.online/ssamenj-logo.png"

# Auth email delivery through Resend. Server-only; never expose RESEND_API_KEY to Vite.
# Production must set AUTH_EMAIL_PROVIDER=RESEND and use a verified Resend sender domain.
# Keep AUTH_EMAIL_REPLY_TO on the support mailbox so replies go to a real human inbox.
AUTH_EMAIL_PROVIDER="RESEND"
# Production AUTH_EMAIL_FROM must use a verified Resend sender domain, not Gmail.
RESEND_API_KEY=""
AUTH_EMAIL_REPLY_TO="support@ssamenj.online"
AUTH_EMAIL_FROM="SSAMENJ Report Lab <support@ssamenj.online>"
OUTREACH_EMAIL_FROM="Joshua from SSAMENJ Technologies <support@ssamenj.online>"
EMAIL_FROM="SSAMENJ Report Lab <support@ssamenj.online>"
RESEND_FROM_EMAIL="SSAMENJ Report Lab <support@ssamenj.online>"

# Auth — generate a strong random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET="dev-secret-change-in-production"
OCR_ENABLED="true"
OCR_PROVIDER="azure"
# Private Railway backend env only. Do not expose this to the frontend.
AZURE_OCR_FUNCTION_URL="https://YOUR-FUNCTION.azurewebsites.net/api/ocr"

# Gemini marksheet OCR — server-only. NEVER add this to Vercel frontend env or
# expose it to the client. Used by /api/marks-import/scan/extract and test routes.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
# Smart Pages model routing — override per tier (leave blank to fall back to GEMINI_MODEL)
# Fast + high-accuracy both use 3.5-flash. Stable fallback used on 429 / timeout / unavailable.
SMART_PAGES_GEMINI_FAST_MODEL="gemini-3.5-flash"
SMART_PAGES_GEMINI_HIGH_ACCURACY_MODEL="gemini-3.5-flash"
SMART_PAGES_GEMINI_STABLE_ACCURACY_MODEL="gemini-2.5-flash"
SMART_PAGES_CREDIT_PRICE_UGX=500
SMART_PAGES_HIGH_ACCURACY_MULTIPLIER=2
SMART_PAGES_GENERATE_DOCUMENT_CREDITS_PER_PAGE=1
SMART_PAGES_PUBLISH_CREDITS_PER_DOCUMENT=1
SMART_PAGES_ACTIVE_VERTICAL=SCHOOL
ENABLE_SMART_PAGES_LAWYERS=false
VITE_ENABLE_SMART_PAGES_LAWYERS=false
SMART_PAGES_AIRTEL_MERCHANT_CODE=7097959
SMART_PAGES_MTN_MERCHANT_CODE=98642335
SMART_PAGES_AIRTEL_MERCHANT_NAME=""
SMART_PAGES_MTN_MERCHANT_NAME=""
# Required on the Gemini test routes when NODE_ENV=production.
INTERNAL_TEST_KEY=""
# Platform admin key for school provisioning — server-only. Never expose to frontend.
# Generate with: openssl rand -hex 32
PLATFORM_ADMIN_KEY=""
SSAMENJ_PLATFORM_INTEGRATION_ENABLED=false
SSAMENJ_PLATFORM_URL=http://localhost:4400
SSAMENJ_PLATFORM_SERVICE_TOKEN=
SSAMENJ_PLATFORM_PRODUCT_CODE=school_connect_suite
# Reader gateway first-time assignment token. Server-only; never expose to the browser.
READER_GATEWAY_PROVISIONING_TOKEN=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_SUPPORT_CHAT_ID="8899226749"
VITE_SUPPORT_MODE="telegram_form"

# Communication Transmission Engine — defaults must not send live messages.
COMMUNICATION_WORKER_ENABLED=false
COMMUNICATION_DRY_RUN=true
COMMUNICATION_BATCH_SIZE=25
COMMUNICATION_MAX_ATTEMPTS=5
COMMUNICATION_BASE_RETRY_SECONDS=60
COMMUNICATION_ALLOW_REAL_RECIPIENTS=false
COMMUNICATION_TEST_RECIPIENT_ALLOWLIST=""

# Meta Cloud WhatsApp — server-only. Never expose these values to Vite/frontend env.
META_GRAPH_API_VERSION="v23.0"
WHATSAPP_META_VERIFY_TOKEN=""
WHATSAPP_META_APP_SECRET=""
WHATSAPP_META_ACCESS_TOKEN=""
WHATSAPP_META_PHONE_NUMBER_ID=""
WHATSAPP_PROVIDER_ENABLED=false

# SMS provider — server-only. Use SMS_PROVIDER=mock for controlled non-vendor testing.
SMS_PROVIDER=mock
SMS_PROVIDER_ENABLED=false
SMS_API_KEY=""
SMS_AUTH_TOKEN=""
SMS_SENDER_ID=""
