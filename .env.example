DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_connect_reports_lab?schema=public"
PORT=4300
VITE_API_BASE_URL="http://localhost:4300"
CLIENT_ORIGIN="http://localhost:5173"

# Auth — generate a strong random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET="dev-secret-change-in-production"
# OCR provider: paddleocr | textract | googlevision | doctr | tesseract | manual
OCR_PROVIDER="googlevision"
PADDLE_OCR_URL="http://localhost:8003"
DOCTR_OCR_URL="http://localhost:8002"

# Google Cloud Vision (only used when OCR_PROVIDER="googlevision")
GOOGLE_APPLICATION_CREDENTIALS="C:\\path\\to\\service-account.json"
GOOGLE_VISION_FEATURE="DOCUMENT_TEXT_DETECTION"

# Amazon Textract (only used when OCR_PROVIDER="textract")
# eu-west-1 (Ireland) is the closest well-supported Textract region.
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
