{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/demo",
      "destination": "https://ssamenj.vercel.app/demos",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/report-lab/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
