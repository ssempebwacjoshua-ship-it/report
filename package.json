{
  "name": "school-connect-reports-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --target=node20 --packages=external --format=esm --outfile=dist/server/index.js",
    "start": "node dist/server/index.js",
    "start:prod": "npx prisma migrate deploy && node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node scripts/prisma-generate-safe.mjs",
    "db:generate:raw": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc -b",
    "seed:preview": "tsx scripts/seed-preview.ts",
    "seed:preview:dry-run": "tsx scripts/seed-preview.ts",
    "seed:preview:apply": "tsx scripts/seed-preview.ts -Apply",
    "seed:admin:dry-run": "tsx scripts/seed-admin.ts",
    "seed:admin:apply": "tsx scripts/seed-admin.ts -Apply",
    "platform-owner:create:dry-run": "tsx scripts/create-platform-owner.ts",
    "platform-owner:create:apply": "tsx scripts/create-platform-owner.ts -Apply",
    "seed:s1-marks:test": "tsx scripts/seed-s1-marks-test.ts",
    "verify:s1-marks:test": "tsx scripts/verify-s1-marks-test.ts",
    "school:structure:dry-run": "tsx src/scripts/repairPreviewClasses.ts",
    "school:structure:apply": "tsx src/scripts/repairPreviewClasses.ts --apply",
    "lint": "eslint .",
    "preview": "vite preview",
    "railway:start": "npm run start:prod",
    "verify:parent-report": "npm test -- ParentReportPage",
    "verify:marksheets": "npm test -- MarksheetsPage",
    "verify:dashboard": "npm test -- DashboardPage",
    "verify:release": "npm test -- reportReleaseMessage",
    "verify:imports": "npm test -- import",
    "verify:report-lab": "npm run verify:parent-report && npm run verify:marksheets && npm run verify:dashboard && npm run verify:release && npm run verify:imports && npm run build",
    "verify:deploy-critical": "vitest run src/tests/ui/LoginPage.test.tsx src/tests/server/cors.test.ts src/tests/ui/ParentReportPage.test.tsx src/tests/ui/ReleaseCenterPage.test.tsx src/tests/services/nfcGateOperations.test.ts src/tests/routes/communicationOutboundRoutes.test.ts && npm run build",
    "verify:repo-health": "npm run typecheck && npm run test:critical && npm run build",
    "test:critical": "vitest run src/tests/ui/LoginPage.test.tsx src/tests/ui/AppShellRoleAccess.test.tsx src/tests/security/permissionRoutes.test.ts src/tests/client/studentsClient.test.ts src/tests/routes/studentsPassportPhotoRoute.test.ts src/tests/services/nfcGateOperations.test.ts src/tests/routes/nfcOperationsGateRoutes.test.ts src/tests/routes/nfcGateAuthenticatedFlow.test.ts src/tests/ui/NfcGateSecurityPage.test.tsx src/tests/services/documentIntelligenceService.test.ts src/tests/routes/documentIntelligenceRoutes.vertical.test.ts src/tests/ui/ParentReportPage.test.tsx",
    "check:migrations": "tsx scripts/check-migration-safety.ts",
    "check:smart-pages-verticals": "tsx scripts/check-smart-pages-vertical-leakage.ts"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.330",
    "@google/genai": "^2.8.0",
    "@prisma/client": "^6.19.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/sharp": "^0.31.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dexie": "^4.4.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.20.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "resend": "^6.17.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
